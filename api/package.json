{
  "name": "devconsole-api",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "start:prod": "node --max_semi_space_size=64 --max-old-space-size=400 --optimize-for-size ./dist/index.js",
    "start": "nodemon",
    "build": "tsc -p tsconfig.build.json",
    "build:clean": "rm -rf ./dist",
    "prebuild": "npm run build:clean",
    "lint": "eslint 'src/**/*.ts' --ignore-pattern '**/*.test.ts' --ignore-pattern '**/__tests__/**' --fix",
    "test": "TZ='UTC' jest --maxWorkers=50% --coverage --config ./internals/testing/jest.config.js --silent=false || true"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "dependencies": {
    "@capillarytech/arya": "38.4.4",
    "body-parser": "^1.20.0",
    "cookie-parser": "^1.4.6",
    "cors": "^2.8.5",
    "dotenv": "^16.0.3",
    "express": "^4.19.2",
    "helmet": "^7.0.0",
    "http-status": "^2.1.0"
  },
  "devDependencies": {
    "@types/cookie-parser": "^1.4.6",
    "@types/cors": "^2.8.12",
    "@types/express": "^4.17.21",
    "@types/jest": "^29.5.4",
    "@types/node": "^20.5.4",
    "@typescript-eslint/eslint-plugin": "^6.7.2",
    "@typescript-eslint/parser": "^6.7.2",
    "eslint": "^8.49.0",
    "eslint-config-prettier": "^9.0.0",
    "eslint-plugin-import": "^2.28.1",
    "eslint-plugin-jest": "^27.2.3",
    "eslint-plugin-prettier": "^5.0.0",
    "eslint-plugin-sonarjs": "^0.21.0",
    "jest": "^29.6.3",
    "jest-sonar-reporter": "^2.0.0",
    "nodemon": "^3.0.1",
    "prettier": "^3.0.3",
    "supertest": "^6.3.3",
    "ts-jest": "^29.1.1",
    "ts-node": "^10.9.1",
    "typescript": "^5.1.6"
  }
}
