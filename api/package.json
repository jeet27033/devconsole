{
  "name": "devconsole-api",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "start:prod": "node --max_semi_space_size=64 --max-old-space-size=400 --optimize-for-size ./dist/index.js",
    "start": "nodemon",
    "build": "tsc -p tsconfig.build.json",
    "build:clean": "rm -rf ./dist",
    "prebuild": "npm run build:clean",
    "lint": "eslint 'src/**/*.ts' --ignore-pattern '**/*.test.ts' --ignore-pattern '**/__tests__/**' --fix",
    "test": "TZ='UTC' jest --maxWorkers=50% --coverage --config ./internals/testing/jest.config.js --silent=false || true"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "dependencies": {
    "@capillarytech/arya": "38.4.4",
    "body-parser": "^2.2.2",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.6",
    "dotenv": "^17.4.1",
    "express": "^5.2.1",
    "helmet": "^8.1.0",
    "http-status": "^2.1.0"
  },
  "devDependencies": {
    "@types/cookie-parser": "^1.4.10",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/jest": "^30.0.0",
    "@types/node": "^22.15.0",
    "@typescript-eslint/eslint-plugin": "^7.18.0",
    "@typescript-eslint/parser": "^7.18.0",
    "eslint": "^8.57.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-jest": "^28.14.0",
    "eslint-plugin-prettier": "^5.5.5",
    "eslint-plugin-sonarjs": "^4.0.2",
    "jest": "^30.3.0",
    "jest-sonar-reporter": "^2.0.0",
    "nodemon": "^3.1.14",
    "prettier": "^3.8.2",
    "supertest": "^7.2.2",
    "ts-jest": "^29.4.9",
    "ts-node": "^10.9.2",
    "typescript": "^5.8.3"
  }
}
